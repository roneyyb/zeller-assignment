# Copy to `.env` and adjust. Expo only exposes vars prefixed with EXPO_PUBLIC_ to your app bundle.
# https://docs.expo.dev/guides/environment-variables/

# development | staging | production
EXPO_PUBLIC_APP_ENV=development

# Optional: override when you add a backend
# EXPO_PUBLIC_API_URL=https://api.example.com

# AppSync (GraphQL)
# Provide values from `aws-exports.js` (do not commit real API keys).
EXPO_PUBLIC_APPSYNC_GRAPHQL_ENDPOINT=https://example.com/graphql
EXPO_PUBLIC_APPSYNC_API_KEY=replace-me
EXPO_PUBLIC_APPSYNC_REGION=ap-southeast-2

